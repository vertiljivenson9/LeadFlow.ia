# LeadFlow AI Environment Variables

# ===========================================
# REQUIRED SECRETS (set via `wrangler secret put`)
# ===========================================

# JWT secret for access tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# JWT secret for refresh tokens (generate with: openssl rand -base64 32)
JWT_REFRESH_SECRET=your-refresh-secret-here

# Resend API key for sending emails
RESEND_API_KEY=re_xxxxxxxxxxxx

# ===========================================
# OPTIONAL VARIABLES (set in wrangler.toml [vars])
# ===========================================

# Rate limiting: max requests per window
RATE_LIMIT_REQUESTS=100

# Rate limiting: window in seconds
RATE_LIMIT_WINDOW=60

# Environment (development, staging, production)
ENVIRONMENT=development

# ===========================================
# CLOUDFLARE RESOURCES (created via wrangler)
# ===========================================

# D1 Database ID (after running: wrangler d1 create leadflow-db)
# D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# KV Namespace ID (after running: wrangler kv:namespace create KV)
# KV_NAMESPACE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Queue Name (after running: wrangler queues create leadflow-queue)
# QUEUE_NAME=leadflow-queue

# R2 Bucket Name (after running: wrangler r2 bucket create leadflow-exports)
# R2_BUCKET_NAME=leadflow-exports

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================

# Local development port
DEV_PORT=8787

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ===========================================
# TESTING
# ===========================================

# Test JWT secret (used in vitest.config.ts)
# TEST_JWT_SECRET=test-jwt-secret-key

# Test database ID
# TEST_DATABASE_ID=test-database-id
